{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Vite Frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "Express API Server",
      "runtimeExecutable": "node",
      "runtimeArgs": ["server/index.js"],
      "port": 3001
    },
    {
      "name": "Full Stack (Vite + API via concurrently)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:full"],
      "port": 3000
    },
    {
      "name": "Preview (static build)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["scripts/serve-static-preview.cjs", "--host", "127.0.0.1", "--port", "4173"],
      "port": 4173
    },
    {
      "name": "Module 1 (standalone)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "module1"],
      "port": 3000
    },
    {
      "name": "Module 3 (standalone)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "module3"],
      "port": 3000
    },
    {
      "name": "Module 4 (standalone)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "module4"],
      "port": 3000
    }
  ]
}
